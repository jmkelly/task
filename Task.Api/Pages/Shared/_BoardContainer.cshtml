@model global::Task.Api.Pages.IndexModel

<div id="board-container" class="board-container">
    <section class="board-section" aria-label="Kanban board layout">
        <div class="board-shell">
            <div class="board-toolbar">
                <div class="board-focus-copy"></div>

                @await Html.PartialAsync("_BoardFilters", Model)
            </div>

            <div id="board" class="board-surface" hx-get="/Index?handler=Refresh" hx-trigger="every 5s" hx-include="#filter-form" hx-target="#board-container" hx-swap="outerHTML">
                @await Html.PartialAsync("_KanbanBoard", Model.TaskItems)
            </div>
        </div>
    </section>
</div>
