<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>@ViewData["Title"] - Task Kanban Board</title>
    <script src="https://unpkg.com/htmx.org@2.0.8"></script>
    <script src="https://unpkg.com/htmx.org@2.0.8/dist/ext/ws.js"></script>
    <link rel="stylesheet" href="~/styles.css" />
</head>
<body>
    <header>
        <div class="header-inner">
            <div class="header-brand" aria-label="Task board home">
                <span class="header-brand-mark">T</span>
                <span class="header-brand-copy">
                    <strong>Task</strong>
                    <span>Kanban board</span>
                </span>
            </div>

            <button class="btn-secondary theme-toggle" id="theme-toggle" aria-label="Switch to light theme" title="Switch to light theme">
                <span class="theme-toggle-icon" id="theme-toggle-icon">☀</span>
            </button>
        </div>
    </header>

    <main class="main-container">
        @RenderBody()
    </main>

    <footer>
        © @DateTime.Now.Year Task · Focused task management for local teams and agents.
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
