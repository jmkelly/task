@page
@using Task.Api.Pages
@model IndexModel
@{
    ViewData["Title"] = "Task Board";
}

<section class="page-toolbar" aria-label="Board controls">
    <div class="page-toolbar-copy">
        <h1 class="page-title"><span class="emoji emoji-leading">🚀</span>Task Board</h1>
    </div>

    <div class="page-actions">
        <button class="btn-primary" hx-get="/Index?handler=CreateModal" hx-target="body" hx-swap="beforeend">
            <span class="emoji emoji-leading">➕</span>Add Task
        </button>
        <button class="btn-secondary" hx-post="/Index?handler=ClearBoard" hx-include="#filter-form" hx-target="#board-container" hx-swap="outerHTML" onclick="return confirm('Are you sure you want to clear all tasks? This action cannot be undone.')">
            <span class="emoji emoji-leading">🗑️</span>Clear Board
        </button>
    </div>
</section>

@await Html.PartialAsync("_BoardContainer", Model)

<div id="modal-container"></div>

@await Html.PartialAsync("_BlockReasonModal")

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        document.addEventListener('htmx:configRequest', function (event) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                event.detail.headers['RequestVerificationToken'] = token.value;
            }
        });

        let draggedElement = null;

        function handleDragStart(event) {
            draggedElement = event.target;
            event.target.classList.add('dragging');
            event.dataTransfer.setData('text/plain', event.target.dataset.uid);
        }

        function buildStatusUpdatePayload(uid, status, blockReason) {
            const filterForm = document.getElementById('filter-form');
            const formData = filterForm ? new FormData(filterForm) : new FormData();
            formData.append('uid', uid);
            formData.append('status', status);

            if (typeof blockReason === 'string') {
                formData.append('blockReason', blockReason);
            }

            return Object.fromEntries(formData);
        }

        function updateTaskStatus(uid, status, blockReason) {
            if (!uid || !status) {
                return;
            }

            const payload = buildStatusUpdatePayload(uid, status, blockReason);
            htmx.ajax('POST', '/Index?handler=UpdateStatus', {
                values: payload,
                target: '#board-container',
                swap: 'outerHTML'
            });
        }

        function openBlockReasonModal(uid, status) {
            const template = document.getElementById('block-reason-modal-template');
            if (!template || !template.content) {
                updateTaskStatus(uid, status, '');
                return;
            }

            const existingModal = document.querySelector('[data-block-reason-modal]');
            if (existingModal) {
                existingModal.remove();
            }

            const modal = template.content.firstElementChild.cloneNode(true);
            const form = modal.querySelector('[data-block-reason-form]');
            const input = modal.querySelector('[data-block-reason-input]');
            const cancelButton = modal.querySelector('[data-block-reason-cancel]');

            function closeModal() {
                modal.remove();
            }

            if (cancelButton) {
                cancelButton.addEventListener('click', closeModal);
            }

            if (form) {
                form.addEventListener('submit', function (event) {
                    event.preventDefault();
                    const reason = input && typeof input.value === 'string' ? input.value.trim() : '';
                    updateTaskStatus(uid, status, reason);
                    closeModal();
                });
            }

            document.body.appendChild(modal);

            if (input) {
                input.focus();
            }
        }

        function handleDrop(event) {
            event.preventDefault();
            const uid = event.dataTransfer.getData('text/plain');
            const column = event.currentTarget.closest('.kanban-column');
            const status = column ? column.dataset.status : '';

            if (!uid || !status || !draggedElement) {
                return;
            }

            draggedElement.classList.remove('dragging');

            if (status === 'blocked') {
                openBlockReasonModal(uid, status);
                return;
            }

            updateTaskStatus(uid, status, '');
        }

        function updateFilterToggleState(toggleButton, advancedFilters, shouldExpand) {
            const isExpanded = shouldExpand ?? toggleButton.getAttribute('aria-expanded') === 'true';
            const nextState = !isExpanded;
            toggleButton.setAttribute('aria-expanded', String(nextState));
            toggleButton.dataset.manualState = 'true';
            advancedFilters.classList.toggle('is-visible', nextState);
        }

        function syncFilterToggleForViewport() {
            const toggleButton = document.querySelector('[data-filter-toggle]');
            const advancedFilters = document.querySelector('[data-filter-advanced]');

            if (!toggleButton || !advancedFilters) {
                return;
            }

            const isDesktop = window.matchMedia('(min-width: 721px)').matches;

            if (isDesktop) {
                toggleButton.setAttribute('aria-expanded', 'true');
                advancedFilters.classList.add('is-visible');
                delete toggleButton.dataset.manualState;
                return;
            }

            const hasManualState = toggleButton.dataset.manualState === 'true';
            if (!hasManualState) {
                toggleButton.setAttribute('aria-expanded', 'false');
                advancedFilters.classList.remove('is-visible');
            }
        }

        function initTheme() {
            const stored = localStorage.getItem('theme');
            const html = document.documentElement;

            if (stored === 'light' || stored === 'dark') {
                html.dataset.theme = stored;
            } else {
                html.dataset.theme = 'auto';
            }

            updateThemeIcon();
        }

        function getEffectiveTheme() {
            const theme = document.documentElement.dataset.theme;
            if (theme === 'light' || theme === 'dark') {
                return theme;
            }

            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        function updateThemeIcon() {
            const icon = document.getElementById('theme-toggle-icon');
            if (!icon) {
                return;
            }

            icon.textContent = getEffectiveTheme() === 'dark' ? '☀️' : '🌙';
        }

        function toggleTheme() {
            const html = document.documentElement;
            const current = getEffectiveTheme();
            const next = current === 'dark' ? 'light' : 'dark';

            html.dataset.theme = next;
            localStorage.setItem('theme', next);
            updateThemeIcon();
        }

        document.addEventListener('click', function (event) {
            const toggleButton = event.target.closest('[data-filter-toggle]');
            if (!toggleButton) {
                return;
            }

            const advancedFilters = document.querySelector('[data-filter-advanced]');
            if (!advancedFilters) {
                return;
            }

            updateFilterToggleState(toggleButton, advancedFilters);
        });

        document.addEventListener('DOMContentLoaded', function () {
            initTheme();

            const themeToggle = document.getElementById('theme-toggle');
            if (themeToggle) {
                themeToggle.addEventListener('click', toggleTheme);
            }

            const colorSchemeQuery = window.matchMedia('(prefers-color-scheme: dark)');
            const handleColorSchemeChange = function () {
                if (localStorage.getItem('theme') !== 'light' && localStorage.getItem('theme') !== 'dark') {
                    updateThemeIcon();
                }
            };

            if (typeof colorSchemeQuery.addEventListener === 'function') {
                colorSchemeQuery.addEventListener('change', handleColorSchemeChange);
            } else if (typeof colorSchemeQuery.addListener === 'function') {
                colorSchemeQuery.addListener(handleColorSchemeChange);
            }

            syncFilterToggleForViewport();
            window.addEventListener('resize', syncFilterToggleForViewport);

            document.body.addEventListener('htmx:afterSwap', function (event) {
                const target = event.detail && event.detail.target;
                if (target && target.id === 'board-container') {
                    syncFilterToggleForViewport();
                }
            });

            document.addEventListener('dragover', function (event) {
                event.preventDefault();
                const column = event.target.closest('.kanban-column');
                if (column) {
                    column.classList.add('drag-over');
                }
            });

            document.addEventListener('dragleave', function (event) {
                const column = event.target.closest('.kanban-column');
                if (column && !column.contains(event.relatedTarget)) {
                    column.classList.remove('drag-over');
                }
            });

            document.addEventListener('drop', function () {
                document.querySelectorAll('.kanban-column').forEach(function (column) {
                    column.classList.remove('drag-over');
                });
            });

            document.addEventListener('dragend', function () {
                document.querySelectorAll('.dragging').forEach(function (element) {
                    element.classList.remove('dragging');
                });

                document.querySelectorAll('.kanban-column').forEach(function (column) {
                    column.classList.remove('drag-over');
                });
            });
        });
    </script>
}
